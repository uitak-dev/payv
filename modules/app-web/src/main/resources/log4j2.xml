<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <!-- Outbox polling SQL logs are too noisy at 2s interval; keep this mapper at INFO -->
        <Logger name="com.payv.ledger.infrastructure.persistence.mybatis.mapper.LedgerEventOutboxMapper" level="info" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <Logger name="com.payv" level="debug" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="ConsoleAppender"/>
        </Root>
    </Loggers>
</Configuration>
